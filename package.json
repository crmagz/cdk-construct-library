{
  "name": "@cdk-construct/library",
  "description": "AWS CDK construct library",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crmagz/cdk-construct-library.git"
  },
  "scripts": {
    "build": "projen build",
    "clean": "projen clean",
    "clobber": "projen clobber",
    "compile": "projen compile",
    "default": "projen default",
    "deploy": "projen deploy",
    "eject": "projen eject",
    "format": "projen format",
    "format:check": "projen format:check",
    "lint": "projen lint",
    "package": "projen package",
    "post-compile": "projen post-compile",
    "pre-compile": "projen pre-compile",
    "release:check": "projen release:check",
    "release:preview": "node scripts/preview-package-releases.mjs --ferrflow-version 5.2.4",
    "security": "projen security",
    "test": "projen test",
    "test:watch": "projen test:watch",
    "watch": "projen watch",
    "projen": "projen",
    "hooks:install": "lefthook install",
    "hooks:run": "lefthook run pre-commit && lefthook run pre-push",
    "prepare": "lefthook install"
  },
  "author": {
    "name": "crmagz",
    "email": "33166233+crmagz@users.noreply.github.com",
    "organization": false
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "24.13.2",
    "aws-cdk": "2.1126.0",
    "aws-cdk-lib": "2.258.1",
    "cdk-nag": "3.0.0",
    "constructs": "10.6.0",
    "eslint": "^9.37.0",
    "gts": "^7.0.0",
    "jest": "^30.2.0",
    "jest-junit": "^17",
    "lefthook": "2.1.9",
    "prettier": "^3.8.1",
    "projen": "0.99.71",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3"
  },
  "peerDependencies": {
    "aws-cdk-lib": "^2.258.1",
    "constructs": "^10.6.0"
  },
  "keywords": [
    "aws-cdk",
    "cdk",
    "constructs",
    "esm",
    "typescript"
  ],
  "engines": {
    "node": ">= 20.0.0"
  },
  "devEngines": {
    "packageManager": {
      "name": "npm",
      "version": "11.16.0",
      "onFail": "warn"
    }
  },
  "main": "lib/index.js",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.0",
  "jest": {
    "coverageProvider": "v8",
    "testMatch": [
      "<rootDir>/packages/*/@(src|test)/**/*(*.)@(spec|test).ts?(x)",
      "<rootDir>/packages/*/@(src|test)/**/__tests__/**/*.ts?(x)"
    ],
    "clearMocks": true,
    "collectCoverage": true,
    "coverageReporters": [
      "json",
      "lcov",
      "clover",
      "cobertura",
      "text"
    ],
    "coverageDirectory": "coverage",
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "watchPathIgnorePatterns": [
      "/node_modules/"
    ],
    "reporters": [
      "default",
      [
        "jest-junit",
        {
          "outputDirectory": "test-reports"
        }
      ]
    ],
    "transform": {
      "^.+\\.[t]sx?$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.dev.json",
          "useESM": true
        }
      ]
    },
    "preset": "ts-jest/presets/default-esm",
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^@cdk-construct/core$": "<rootDir>/packages/core/src/index.ts",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "types": "lib/index.d.ts",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "packageManager": "npm@11.16.0",
  "exports": {
    ".": {
      "types": "./lib/index.d.ts",
      "import": "./lib/index.js"
    }
  },
  "sideEffects": false,
  "//": "~~ Generated by projen. To modify, edit .projenrc.ts and run \"npx projen\"."
}
